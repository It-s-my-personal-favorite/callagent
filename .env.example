# Beispiel-Umgebungsvariablen für CallAgent (Root-Workspace).
# Kopie: copy .env.example .env — .env niemals committen (steht in .gitignore).
#
# Für Docker/Monorepo unter frontend/ siehe zusätzlich: frontend/.env.example

# ===== Database Backend Configuration =====
# Entweder "sqlite" (Standard, keine Installation) oder "postgres"

# SQLite (Entwicklung)
# DB_BACKEND=sqlite
# SQLITE_PATH=callagent.db

# PostgreSQL (Produktion / lokal mit Postgres)
DB_BACKEND=postgres
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=callagent
PG_ADMIN_DATABASE=postgres

# ===== Flask =====
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# ===== Twilio (echte Werte nur in lokaler .env) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===== WebSocket / öffentliche URLs (z. B. ngrok) =====
WEBSOCKET_URL=wss://your-ngrok-url.ngrok-free.dev/audiostream-test
SELF_URL=localhost:5000

# ===== Sprach- und LLM-Dienste =====
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENROUTER_API_KEY=

# ===== Wasabi (optional, S3-kompatibel) =====
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET_NAME=
WASABI_ENDPOINT_URL=https://s3.eu-central-2.wasabisys.com
