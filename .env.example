# Ports (optional overrides)
API_PORT=5000
BOT_PORT=7860

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-secret-key

# PostgreSQL (required by `config.py`)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=callagent
PG_ADMIN_DATABASE=postgres

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# URLs (Twilio stream / public callback)
WEBSOCKET_URL=wss://your-public-url.example/ws
SELF_URL=localhost:5000

# Wasabi / S3-compatible storage
WASABI_ACCESS_KEY=your_access_key_here
WASABI_SECRET_KEY=your_secret_key_here
WASABI_BUCKET_NAME=your-bucket-name
WASABI_ENDPOINT_URL=https://s3.eu-central-2.wasabisys.com

# Gemini / Google
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_API_KEY=your_google_api_key_here

# Speech services
DEEPGRAM_API_KEY=your_deepgram_api_key
CARTESIA_API_KEY=your_cartesia_api_key
