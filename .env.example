# Database Backend Configuration
# Choose either "sqlite" (default, no install required) or "postgres"

# ===== SQLite Mode (Development - No Installation Required) =====
# DB_BACKEND=sqlite
# SQLITE_PATH=callagent.db

# ===== PostgreSQL Mode (Production) =====
DB_BACKEND=postgres
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=callagent
PG_ADMIN_DATABASE=postgres

# ===== Flask Configuration =====
FLASK_ENV=development
SECRET_KEY=change-this-secret-key

# ===== Twilio Configuration =====
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===== WebSocket Configuration =====
WEBSOCKET_URL=wss://your-ngrok-url.ngrok-free.dev/audiostream-test
SELF_URL=localhost:5000

# ===== Wasabi Configuration =====
WASABI_ACCESS_KEY = 'your_access_key_here'
WASABI_SECRET_KEY = 'your_secret_key_here'
WASABI_BUCKET_NAME = 'your-bucket-name'
WASABI_ENDPOINT_URL = 'https://s3.eu-central-2.wasabisys.com'