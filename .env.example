# Beispiel-Umgebungsvariablen für CallAgent (Root-Workspace).
# Kopie:  copy .env.example .env   —  .env niemals committen (steht in .gitignore).
#
# Für Docker/Monorepo unter frontend/ siehe zusätzlich: frontend/.env.example

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=ifindappointments
PG_ADMIN_DATABASE=postgres

# Twilio (Platzhalter — echte Werte nur in lokaler .env)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Sprach-/LLM-Dienste (nur in .env setzen, nicht echte Keys hier eintragen)
DEEPGRAM_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
CARTESIA_API_KEY=
OPENROUTER_API_KEY=

# Wasabi S3-kompatibel (optional)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET_NAME=
WASABI_ENDPOINT_URL=https://s3.eu-central-2.wasabisys.com

# Öffentliche Basis-URLs (z. B. ngrok-Host ohne https:// falls nur Hostname)
SELF_URL=localhost
WEBSOCKET_URL=wss://localhost/audiostream-test
