# Kopiere diese Datei nach .env und setze deine echte URL (nicht committen).
# Schema: postgresql://USER:PASS@HOST:PORT/DATABASE
#
# Hinweis: URLs mit postgres:// werden automatisch zu postgresql:// normalisiert.
# Viele gehostete Postgres-Instanzen brauchen SSL, z. B.:
# DATABASE_URL=postgresql://user:pass@host:5432/postgres?sslmode=require

DATABASE_URL=postgresql://postgres:password@localhost:5432/ifindappointments
