# apps/marketing-site — öffentliche Variablen (NEXT_PUBLIC_* im Client sichtbar)
# Für lokale Entwicklung: Kopie als .env.local (siehe .env.local.example). Nichts Geheimes committen.

NEXT_PUBLIC_HELP_PHONE=0800 000 00 00
# E.164 inkl. Ländervorwahl für zuverlässige tel:-Links (z. B. +498001234567)
NEXT_PUBLIC_HELP_PHONE_TEL=+498000000000
NEXT_PUBLIC_HELP_HOURS=Mo–Fr 8:00–20:00 Uhr · kostenfrei (Festnetz, Mobilfunk ggf. laut Anbieter)

NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_SITE_URL=https://callagent.app

# Optional: Reverse-Proxy nur wenn Landing einen Host an Flutter/Backend durchreicht
# CALLAGENT_APP_UPSTREAM=http://127.0.0.1:8080
# CALLAGENT_APP_PROXY_HOST=app.ihre-domain.de
