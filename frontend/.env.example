# CallAgent — Docker Compose & lokale Orchestrierung
# Kopie nach .env im Ordner frontend/ (nicht committen; .gitignore enthält .env)

# PostgreSQL (muss mit docker-compose.yml und backend/.env übereinstimmen)
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# FastAPI
BACKEND_PORT=8000

# Optional: Default für voice_settings.localServerUrl beim ersten DB-Bootstrap (siehe backend/app.py)
# LOCAL_SERVER_URL=https://dein-ngrok-oder-voice-host.example.com

# Flutter-Admin hinter nginx
ADMIN_WEB_PORT=8080
